#!/usr/bin/env bash
# nadia pre-commit gate — the EXECUTABLE form of AGENTS.md's rule:
#   "make build and make leakage-static MUST both exit 0 before any commit
#    that touches patches/, overlay/, tools/, or nadia-rename.yaml."
#
# Why this exists (2026-05-31): a sync conflict was "resolved" by hand-driving
# quilt and then committing with `git commit --amend`, which bypassed the
# build verification that `make sync-resume` runs. A `quilt refresh` against a
# pristine file had silently dropped a patch hunk; the broken patch got
# committed because nothing physically blocked it. This hook makes the gate
# unbypassable on the normal path. Do NOT use `git commit --no-verify`.
#
# Enable once after clone:  make install-hooks   (sets core.hooksPath=.githooks)
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

# Build-affecting paths. A commit touching any of these must pass the gate.
gated='^(patches/|overlay/|tools/|nadia-rename\.yaml$)'
staged="$(git diff --cached --name-only --diff-filter=ACMR || true)"

if ! printf '%s\n' "$staged" | grep -qE "$gated"; then
  exit 0   # nothing build-affecting staged -> commit freely (docs, tests, etc.)
fi

echo "nadia pre-commit: build-affecting files staged -> running gate (make build + leakage-static)..."

if ! make build >/tmp/nadia-precommit-build.log 2>&1; then
  {
    echo "X pre-commit BLOCKED: 'make build' failed."
    echo "  log: /tmp/nadia-precommit-build.log (tail below)"
    echo "  ----"
    tail -20 /tmp/nadia-precommit-build.log
    echo "  ----"
    echo "  This is the AGENTS.md build gate. Do NOT bypass with --no-verify."
    echo "  If you are mid-sync: resolve in .sync-workdir/ and run 'make sync-resume'."
    echo "  Never hand-edit a patch + 'git commit' a sync -- sync-resume owns the commit."
  } >&2
  exit 1
fi

if ! make leakage-static >/tmp/nadia-precommit-leak.log 2>&1; then
  {
    echo "X pre-commit BLOCKED: 'make leakage-static' failed."
    echo "  log: /tmp/nadia-precommit-leak.log (tail below)"
    echo "  ----"
    tail -20 /tmp/nadia-precommit-leak.log
  } >&2
  exit 1
fi

echo "nadia pre-commit: gate passed."
exit 0
