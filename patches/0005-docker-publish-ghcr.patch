-  IMAGE_NAME: nousresearch/hermes-agent
+  # Image published to GitHub Container Registry under the nadicodeai org.
+  # Note: the new repo's image is `nadia` (NOT `nadia-agent` like the legacy
+  # in-tree-rename fork). Authenticated via the workflow's built-in
+  # GITHUB_TOKEN — no Docker Hub credentials needed.
+  IMAGE_NAME: ghcr.io/nadicodeai/nadia
 
 jobs:
   # ---------------------------------------------------------------------------
@@ -135,12 +139,13 @@ jobs:
           source .venv/bin/activate
           python -m pytest tests/docker/ -v --tb=short
 
-      - name: Log in to Docker Hub
+      - name: Log in to GitHub Container Registry
         if: github.event_name == 'push' && github.ref == 'refs/heads/main' || github.event_name == 'release'
