 class TestBuiltinSkins:
+    def test_argo_skin_loads_with_generated_branding(self):
+        from hermes_cli.skin_engine import load_skin
+        skin = load_skin("argo")
+        assert skin.name == "argo"
+        assert skin.get_branding("agent_name") == "Argo"
+        assert skin.get_color("banner_title") == "#50e3c2"
+        assert skin.get_color("ui_error") == "#cd212a"
+        assert skin.banner_logo == ""
+        assert "⣿⡈⢳⣄" in skin.banner_hero
+        legacy_glyphs = "⚕⚔🐾🔥"
+        rendered = "\n".join([
+            skin.banner_logo,
+            skin.banner_hero,
+            " ".join(skin.spinner.get("thinking_faces", [])),
+            " ".join(skin.spinner.get("thinking_verbs", [])),
+            " ".join(str(value) for value in skin.branding.values()),
+        ])
+        assert not any(glyph in rendered for glyph in legacy_glyphs)
     def test_ares_skin_loads(self):
